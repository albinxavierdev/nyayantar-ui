# Base URL of the deployed backend API (must be https in production).
# Used by the auth page and chat client. No trailing slash.
# For local testing: NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# For deployment: NEXT_PUBLIC_BACKEND_URL=https://your-backend-domain.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Google Identity Services Web Client ID (from Google Cloud Console).
# Required for the "Login with Google" button. Leave blank to hide it.
# When deploying, set this to your production Google OAuth client ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
