# ─────────────────────────────────────────────────────────────
# SECRETS & AUTH (REQUIRED in production — do NOT commit real values)
# ─────────────────────────────────────────────────────────────
# Strong random key for the API. Generate with:
#   python -c "import secrets;print(secrets.token_urlsafe(32))"
# If unset, the server REFUSES TO START (fail-closed).
API_KEY=

# Secret used to sign session tokens (HMAC). Generate with:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
# Required for signed sessions. Refuses to start if missing.
SECRET_KEY=

# Set to "true" ONLY for local dev without the keys above. Never in production.
AUTH_DISABLED=false

# ─────────────────────────────────────────────────────────────
# LOGIN CREDENTIALS
# ─────────────────────────────────────────────────────────────
# Option A (legacy single shared account):
AUTH_USER=
AUTH_PASSWORD=
# Option B (recommended, multi-user): JSON file of hashed users.
#   { "users": [ { "email": "...", "password_hash": "<bcrypt>", "role": "user|admin" } ] }
# Generate a hash with: python -c "import bcrypt;print(bcrypt.hashpw(b'pw',bcrypt.gensalt()).decode())"
USERS_FILE=users.json
# Emails granted the admin role (server-enforced), comma-separated.
ADMIN_EMAILS=

# ─────────────────────────────────────────────────────────────
# GOOGLE OAUTH (Google Identity Services)
# ─────────────────────────────────────────────────────────────
# Web client ID from Google Cloud Console. Required for the SSO button.
GOOGLE_CLIENT_ID=
# Restrict sign-in to one org domain (leave blank to allow any Gmail).
GOOGLE_ALLOWED_DOMAIN=

# ─────────────────────────────────────────────────────────────
# BRUTE-FORCE / LOCKOUT
# ─────────────────────────────────────────────────────────────
MAX_FAILED_LOGINS=5
LOCKOUT_SECONDS=300
IP_BAN_THRESHOLD=50
# hCaptcha secret (optional). When set, locked accounts must solve a CAPTCHA.
HCAPTCHA_SECRET=

# ─────────────────────────────────────────────────────────────
# CONSENT (GDPR-style, server-enforced when true)
# ─────────────────────────────────────────────────────────────
CONSENT_REQUIRED=false

# ─────────────────────────────────────────────────────────────
# CORS / ORIGINS
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────
# NETWORK  (⚠ TLS REQUIRED — terminate HTTPS at a reverse proxy)
# ─────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ─────────────────────────────────────────────────────────────
# SESSION COOKIE SECURITY
# ─────────────────────────────────────────────────────────────
SECURE_COOKIES=true
SAME_SITE=lax
SESSION_COOKIE_NAME=ny_session
SESSION_MAX_AGE=28800
CONSENT_COOKIE_NAME=ny_consent

# ─────────────────────────────────────────────────────────────
# LIMITS
# ─────────────────────────────────────────────────────────────
MAX_QUERY_LENGTH=4000
MAX_BODY_BYTES=524288
RATE_LIMIT_TAGS=30/minute
RATE_LIMIT_TEST_LOCAL=20/minute
RATE_LIMIT_TEST_CLOUD=20/minute
RATE_LIMIT_QUERY=20/minute
RATE_LIMIT_QUERY_STREAM=20/minute
RATE_LIMIT_LOGIN=10/minute

# ─────────────────────────────────────────────────────────────
# MODEL / PROVIDER TOKENS
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=<your-groq-api-key>
HF_TOKEN=

# ─────────────────────────────────────────────────────────────
# BIZFYLABS RAG API
# ─────────────────────────────────────────────────────────────
# Create an API key at https://rag.bizfylabs.com (Admin → API keys)
RAG_API_KEY=sk-rag-your-key-here
RAG_BASE_URL=https://rag.bizfylabs.com


# ─────────────────────────────────────────────────────────────
# SPEECH-TO-TEXT (local Whisper)
# ─────────────────────────────────────────────────────────────
# Whisper model size for /stt endpoint: tiny, base, small, medium, large
WHISPER_MODEL=base

# ─────────────────────────────────────────────────────────────
# APPLICATION DATABASE (users / sessions / queries / audit log)
# ─────────────────────────────────────────────────────────────
# Path to the SQLite file that stores all runtime application data.
# Leave default to use data/app.db (created automatically on first run).
APP_DB_PATH=data/app.db
